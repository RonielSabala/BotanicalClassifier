{
  // Python config
  "python.terminal.activateEnvironment": true,
  "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
  // Markdown config
  "markdown.extension.toc.levels": "2..3",
  "markdown.extension.toc.omittedFromToc": {
    "README.md": ["## Table of Contents"]
  },
  // Project-specific words that should not be flagged as typos
  "cSpell.words": [
    "activebackground",
    "activeforeground",
    "cognitiveservices",
    "columnspan",
    "customvision",
    "dotenv",
    "msrest",
    "nsew",
    "padx",
    "pady",
    "pyproject",
    "relx",
    "selectforeground",
    "shutil",
    "textvariable",
    "tkinter"
  ]
}
